# Copia este archivo a .env y llena los valores.
# La URL y la anon key de Supabase son PÚBLICAS por diseño (mismas que usan
# las apps del POS) — el agente NO usa el service_role. Su credencial real
# es el `agente_token` por impresora, configurado en printers.config.json
# (se genera y consulta desde Admin → Impresoras).

SUPABASE_URL=https://zyjtnaystsporbuzcmqk.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inp5anRuYXlzdHNwb3JidXpjbXFrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEyNzMxNDksImV4cCI6MjA5Njg0OTE0OX0.USpCrgpCLMXcpWhA60mKmgMchrxCR3_kybIPIyas7iA

# Ruta al archivo de configuración de impresoras de ESTE equipo (ver
# printers.config.example.json). Por defecto busca ./printers.config.json
PRINTERS_CONFIG_PATH=./printers.config.json

# Identificador legible de este agente/equipo (aparece en trabajos_impresion.claimed_by)
AGENTE_ID=agente-cocina-01

# Cada cuántos segundos revisa la cola aunque no haya llegado un evento de
# Realtime (respaldo — nunca depender solo de Realtime).
POLL_INTERVALO_SEGUNDOS=10

# Cada cuántos segundos manda "estoy vivo" aunque no haya trabajos.
LATIDO_INTERVALO_SEGUNDOS=30

# Puerto del endpoint local de estado (http://localhost:PUERTO/status).
# Poner en 0 para desactivarlo.
STATUS_HTTP_PUERTO=7777
