{
  "name": "shakeaholic-agente-impresion",
  "version": "1.0.0",
  "private": true,
  "description": "Agente local de impresión de comandas para Shakeaholic POS (ESC/POS, USB/red).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test-print": "tsx src/testPrint.ts",
    "diagnose": "tsx src/diagnose.ts",
    "install-windows-service": "tsx src/installWindowsService.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.5",
    "node-thermal-printer": "^4.6.0"
  },
  "optionalDependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
