VITE_SUPABASE_URL=https://zyjtnaystsporbuzcmqk.supabase.co
VITE_SUPABASE_ANON_KEY=

# Modo de pago del kiosko a usar SOLO si `configuracion_kiosko` (tabla,
# editable desde Admin) todavía no tiene una fila para esta sucursal.
# Valores válidos: clip | pagar_en_caja | demo
# Nunca pongas "demo" aquí para un despliegue real — además de este
# fallback, el código bloquea "demo" en cualquier build de producción
# (import.meta.env.PROD), así que ni siquiera tendría efecto, pero no lo
# dejes configurado por costumbre. Default si se omite: pagar_en_caja.
VITE_KIOSKO_MODO_PAGO_DEFAULT=pagar_en_caja
