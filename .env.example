# ============================================================
# Shakeaholic POS — variables de entorno
# Copia este archivo a .env (raíz) y a apps/<app>/.env según toque.
# NUNCA subas .env a git. NUNCA uses service_role en frontend.
# ============================================================

# --- Frontend (Vite) — seguras de exponer en el navegador ---
# URL pública del proyecto Supabase (proyecto "Shakeaholic")
VITE_SUPABASE_URL=https://zyjtnaystsporbuzcmqk.supabase.co
# anon key (Dashboard > Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=

# --- Server-side / scripts (ETL, edge functions) — SECRETAS ---
# Solo para supabase/seed y funciones server-side. Jamás en apps/.
SUPABASE_URL=https://zyjtnaystsporbuzcmqk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Clip (fase 8 — ver docs/integracion-clip.md) ---
# API key de Clip (server-side únicamente)
CLIP_API_KEY=
# Secreto para validar firmas del webhook de Clip
CLIP_WEBHOOK_SECRET=
# Serial / id de la terminal Clip Stand 2 asignada a la caja
CLIP_TERMINAL_SERIAL=
