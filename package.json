{
  "name": "shake-pos-ecosistema",
  "private": true,
  "version": "0.1.0",
  "description": "Ecosistema POS + Costos de Shakeaholic sobre Supabase",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:costos": "pnpm --filter @shake/costos dev",
    "dev:pos": "pnpm --filter @shake/pos dev",
    "dev:kiosko": "pnpm --filter @shake/kiosko dev",
    "dev:admin": "pnpm --filter @shake/admin dev",
    "dev:cocina-alimentos": "pnpm --filter @shake/cocina-alimentos dev",
    "dev:cocina-bebidas": "pnpm --filter @shake/cocina-bebidas dev",
    "dev:display": "pnpm --filter @shake/cliente-display dev",
    "dev:pwa": "pnpm --filter @shake/cliente-pwa dev",
    "build": "pnpm -r --if-present build",
    "build:costos": "pnpm --filter @shake/costos build",
    "typecheck": "pnpm -r --if-present typecheck",
    "etl:dry": "pnpm --filter @shake/seed migrar -- --dry-run",
    "etl:aplicar": "pnpm --filter @shake/seed migrar -- --aplicar"
  }
}
